# NodeMesh Environment Configuration
# Copy this file to .env and customize for your setup

# ============================================
# COORDINATOR SETTINGS (Tower)
# ============================================

# Host to bind coordinator to (0.0.0.0 for all interfaces)
COORDINATOR_HOST=0.0.0.0

# Port for coordinator API (default: 11434, same as Ollama)
COORDINATOR_PORT=11434

# URL of local Ollama instance (Tower runs Ollama on different port)
OLLAMA_BASE_URL=http://localhost:11435

# Seconds before considering a worker offline
HEARTBEAT_TIMEOUT=30

# ============================================
# WORKER SETTINGS (All Nodes)
# ============================================

# Unique name for this worker node
NODE_NAME=my-worker

# URL of the coordinator (REQUIRED for workers)
# Change this to your Tower's actual IP address!
COORDINATOR_URL=http://192.168.1.100:11434

# Directory containing GGUF models
MODELS_DIR=./models

# Port for worker API
WORKER_PORT=11436

# Port for llama.cpp server
LLAMA_PORT=11437

# ============================================
# PLATFORM-SPECIFIC NOTES
# ============================================

# Debian/Ubuntu:
#   - Install llama.cpp to /usr/local/bin or add to PATH
#   - Models in ~/GGUF-Models

# Windows:
#   - Add llama-server.exe to PATH
#   - Models in %USERPROFILE%\GGUF-Models

# Android/Termux:
#   - llama-server in $PREFIX/bin
#   - Models in ~/storage/shared/AI-Models
#   - Run: termux-setup-storage first

# ============================================
# EXAMPLE CONFIGURATIONS
# ============================================

# Tower (Coordinator + Worker):
# COORDINATOR_URL=  # Leave empty for coordinator-only mode
# NODE_NAME=tower
# MODELS_DIR=/home/kimi/Desktop/GGUF Models

# Debian Laptop:
# COORDINATOR_URL=http://192.168.1.100:11434
# NODE_NAME=debian-laptop
# MODELS_DIR=/home/user/GGUF-Models

# Windows Laptop:
# COORDINATOR_URL=http://192.168.1.100:11434
# NODE_NAME=windows-laptop
# MODELS_DIR=C:\Users\Username\GGUF-Models

# Android Phone:
# COORDINATOR_URL=http://192.168.1.100:11434
# NODE_NAME=android-phone
# MODELS_DIR=/data/data/com.termux/files/home/storage/shared/AI-Models
